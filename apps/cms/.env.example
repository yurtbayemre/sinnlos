# Strapi server
HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=toBeModified
ADMIN_JWT_SECRET=toBeModified
TRANSFER_TOKEN_SALT=toBeModified
JWT_SECRET=toBeModified
ENCRYPTION_KEY=toBeModified

# Database
#
# Local quick start (default): SQLite file — no server required.
# For production / Docker Compose: set DATABASE_CLIENT=postgres and
# uncomment the Postgres block below. The hostname `db` resolves inside
# the Docker Compose network; use `localhost` for a Postgres server
# running directly on your machine.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# DATABASE_CLIENT=postgres
# DATABASE_HOST=db
# DATABASE_PORT=5432
# DATABASE_NAME=sinnlos
# DATABASE_USERNAME=sinnlos
# DATABASE_PASSWORD=sinnlos
# DATABASE_SSL=false

# Public URL used for OAuth redirect construction
PUBLIC_URL=http://localhost:1337

# Microsoft Entra ID (Azure AD)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
