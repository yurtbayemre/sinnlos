# Strapi server
HOST=0.0.0.0
PORT=1337
APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=toBeModified
ADMIN_JWT_SECRET=toBeModified
TRANSFER_TOKEN_SALT=toBeModified
JWT_SECRET=toBeModified
ENCRYPTION_KEY=toBeModified

# Initial Strapi Super Admin
#
# On first boot (when the admin_users table is empty), bootstrap()
# creates a Strapi admin user from these env vars so you don't have
# to click through the registration form after wiping the database.
# Leave them blank to keep the classic interactive flow.
STRAPI_ADMIN_EMAIL=
STRAPI_ADMIN_PASSWORD=
STRAPI_ADMIN_FIRSTNAME=Admin
STRAPI_ADMIN_LASTNAME=User

# Database
#
# Local quick start (default): SQLite file — no server required.
# For production / Docker Compose: set DATABASE_CLIENT=postgres and
# uncomment the Postgres block below. The hostname `db` resolves inside
# the Docker Compose network; use `localhost` for a Postgres server
# running directly on your machine.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# DATABASE_CLIENT=postgres
# DATABASE_HOST=db
# DATABASE_PORT=5432
# DATABASE_NAME=sinnlos
# DATABASE_USERNAME=sinnlos
# DATABASE_PASSWORD=sinnlos
# DATABASE_SSL=false

# Public URL used for OAuth redirect construction
PUBLIC_URL=http://localhost:1337

# Microsoft Entra ID (Azure AD)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# Standalone mode (no Microsoft / Azure)
#
# Local email+password auth works out of the box — leave the MS_* vars
# above empty and the Microsoft provider stays disabled.
# Set LOCAL_REGISTRATION=1 to let users self-register from the sign-in
# page; leave it unset to create accounts in the Strapi admin instead.
LOCAL_REGISTRATION=

# CORS — comma-separated origins allowed to call the Strapi API.
# Defaults to http://localhost:3000 when unset. Set to the Next.js
# public URL in production (Docker Compose passes WEB_PUBLIC_URL).
CORS_ORIGIN=http://localhost:3000

# Revalidation webhook → Next.js
#
# REVALIDATE_SECRET must match the value in apps/web/.env.local; it
# authenticates the cache-invalidation call. WEB_INTERNAL_URL is how the
# CMS reaches Next.js (e.g. http://localhost:3000 locally, http://web:3000
# in Docker Compose). Leave either unset to skip the webhook (content
# refreshes on the ISR timer instead). openssl rand -hex 32
REVALIDATE_SECRET=
WEB_INTERNAL_URL=http://localhost:3000

# SEED_DEMO_DATA=1 populates departments, teams, users, announcements,
# events, wiki pages, kudos, polls and documents on first boot
# (apps/cms/src/seed-demo.ts). All demo users share the password
# "demo1234". Leave unset/0 for a clean database.
SEED_DEMO_DATA=
