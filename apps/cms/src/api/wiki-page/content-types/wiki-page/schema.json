{
  "kind": "collectionType",
  "collectionName": "wiki_pages",
  "info": {
    "singularName": "wiki-page",
    "pluralName": "wiki-pages",
    "displayName": "Wiki Page",
    "description": "A single wiki article"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "title": { "type": "string", "required": true },
    "slug": { "type": "uid", "targetField": "title", "required": true },
    "body": { "type": "richtext" },
    "summary": { "type": "text" },
    "tocEnabled": { "type": "boolean", "default": true },
    "order": { "type": "integer", "default": 0 },
    "tags": { "type": "json" },
    "space": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::wiki-space.wiki-space",
      "inversedBy": "pages"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::wiki-page.wiki-page",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::wiki-page.wiki-page",
      "mappedBy": "parent"
    },
    "author": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "lastEditor": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department",
      "inversedBy": "pages"
    },
    "team": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team",
      "inversedBy": "pages"
    },
    "revisions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::wiki-revision.wiki-revision",
      "mappedBy": "page"
    }
  }
}
