# Next.js public/runtime env
NEXT_PUBLIC_APP_NAME=Sinnlos Intranet
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Strapi backend (server-side only)
STRAPI_URL=http://localhost:1337
STRAPI_PUBLIC_URL=http://localhost:1337

# Shared secret for the Strapi -> Next.js revalidation webhook.
# Must match REVALIDATE_SECRET in apps/cms/.env. Read by
# /api/revalidate to authenticate cache-invalidation calls from the CMS.
# Leave both sides unset to disable the webhook (content then refreshes
# on the ISR timer instead of instantly). openssl rand -hex 32
REVALIDATE_SECRET=

# Default UI language for users who haven't picked one. Supported: en, de.
DEFAULT_LOCALE=en

# Demo mode (local UI work only): set to 1 to bypass auth + Strapi and
# render the in-memory fixture dataset (apps/web/src/lib/demo.ts).
# Never set in production.
DEMO_MODE=

# Auth.js (NextAuth v5)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Microsoft Entra ID (Azure AD) — same app registration as the Strapi side
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# Standalone mode (no Microsoft / Azure)
#
# Leave the AUTH_MICROSOFT_ENTRA_ID_* vars above empty and local
# email+password sign-in (against Strapi) activates automatically.
# Set AUTH_LOCAL_ENABLED=1 to ALSO offer local sign-in next to Microsoft.
# Set LOCAL_REGISTRATION=1 (here and in apps/cms/.env) to show a
# self-registration form on the sign-in page.
AUTH_LOCAL_ENABLED=
LOCAL_REGISTRATION=
