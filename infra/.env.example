# ----------------------------------------------------------------------
# Public URLs (use https://... in production, behind Caddy)
#
# DOMAIN controls Caddy's TLS behaviour:
#   - real hostname           -> automatic Let's Encrypt certificate
#   - unset (localhost)       -> self-signed cert, browser warning
#   - http://localhost        -> plain HTTP (local development only)
# ----------------------------------------------------------------------
DOMAIN=intranet.example.com
WEB_PUBLIC_URL=https://intranet.example.com
CMS_PUBLIC_URL=https://intranet.example.com
APP_NAME=Sinnlos Intranet

# ----------------------------------------------------------------------
# Postgres
# ----------------------------------------------------------------------
DATABASE_NAME=sinnlos
DATABASE_USERNAME=sinnlos
DATABASE_PASSWORD=change-me-please

# ----------------------------------------------------------------------
# Strapi secrets — generate with:  openssl rand -base64 32
# ----------------------------------------------------------------------
APP_KEYS=change-me-1,change-me-2
API_TOKEN_SALT=change-me
ADMIN_JWT_SECRET=change-me
TRANSFER_TOKEN_SALT=change-me
JWT_SECRET=change-me
ENCRYPTION_KEY=change-me

# ----------------------------------------------------------------------
# Auth.js secret (Next.js) — openssl rand -base64 32
# ----------------------------------------------------------------------
AUTH_SECRET=change-me

# ----------------------------------------------------------------------
# Revalidation webhook — shared secret used by Strapi to tell Next.js
# to invalidate its cache tags when content changes. openssl rand -hex 32
# ----------------------------------------------------------------------
REVALIDATE_SECRET=change-me

# ----------------------------------------------------------------------
# Standalone mode (no Microsoft / Azure)
#
# AUTH_LOCAL_ENABLED=1 turns on email+password login alongside Microsoft.
# Omit both AUTH_ and MS_ vars for a pure local setup (auto-detected).
# LOCAL_REGISTRATION=1 adds a self-registration form on the sign-in page.
# STRAPI_ADMIN_* seeds the first Strapi super-admin on a fresh database
# so you don't have to walk through the admin-panel registration form.
# ----------------------------------------------------------------------
AUTH_LOCAL_ENABLED=0
LOCAL_REGISTRATION=0
STRAPI_ADMIN_EMAIL=admin@example.com
STRAPI_ADMIN_PASSWORD=change-me-please

# ----------------------------------------------------------------------
# Microsoft Entra ID (Azure AD) app registration
#
# 1. Portal → App registrations → New registration
# 2. Redirect URIs (Web):
#      - ${WEB_PUBLIC_URL}/api/auth/callback/microsoft-entra-id
#      - ${CMS_PUBLIC_URL}/api/connect/microsoft/callback
# 3. API permissions: openid, profile, email, User.Read, GroupMember.Read.All
# 4. Create a client secret and copy the value below
# ----------------------------------------------------------------------
MS_TENANT_ID=your-tenant-guid-or-common
MS_CLIENT_ID=your-app-client-id
MS_CLIENT_SECRET=your-app-client-secret
