{$DOMAIN:localhost} {
    encode zstd gzip

    # Strapi admin panel and REST/GraphQL API
    @strapi path /api/* /admin* /uploads/* /content-manager/* /content-type-builder/* /users-permissions/* /i18n/* /content-api/*
    reverse_proxy @strapi cms:1337

    # Everything else → Next.js
    reverse_proxy web:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}
