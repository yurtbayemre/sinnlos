# TLS is on by default: with a real DOMAIN Caddy provisions Let's
# Encrypt certificates automatically and redirects 80 -> 443. Without
# DOMAIN it falls back to `localhost` with a self-signed internal cert
# (run `docker compose exec caddy caddy trust` to silence browser
# warnings, or set DOMAIN=http://localhost to opt back into plain HTTP
# for local development).
{$DOMAIN:localhost} {
    encode zstd gzip

    # Next.js Auth.js callbacks (must come before the /api/* catch-all)
    @nextauth path /api/auth/*
    reverse_proxy @nextauth web:3000

    # Strapi admin panel and REST/GraphQL API
    @strapi path /api/* /admin* /uploads/* /content-manager/* /content-type-builder/* /users-permissions/* /i18n/* /content-api/*
    reverse_proxy @strapi cms:1337

    # Everything else → Next.js
    reverse_proxy web:3000

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}
