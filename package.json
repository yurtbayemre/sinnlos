{
  "name": "sinnlos-intranet",
  "private": true,
  "version": "0.1.0",
  "description": "Self-hosted intranet platform: Strapi v5 + Next.js 16 + Microsoft Entra ID login",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm -r --parallel start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cms:dev": "pnpm --filter @sinnlos/cms dev",
    "web:dev": "pnpm --filter @sinnlos/web dev"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.11.0 <=24.x.x",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "axios@<1.16.0": ">=1.16.0",
      "shell-quote@<1.8.4": ">=1.8.4",
      "tmp@<0.2.6": ">=0.2.6",
      "form-data@<4.0.6": ">=4.0.6"
    }
  }
}
